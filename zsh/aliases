# Git Alias Commands
alias g="git status"
alias ga="git add"
alias gaa="git add ."
alias gau="git add -u"
alias gc="git commit -m '<blank>'"
alias gca="git commit -am"
alias gb="git branch"
alias gbd="git branch -d"
alias gco="git checkout"
alias gcob="git checkout -b"
alias gt="git stash"
alias gta="git stash apply"
alias gm="git merge"
alias gr="git rebase"
alias gl="git log --oneline --decorate --graph"
alias glog="git log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --"
alias glga="git log --graph --oneline --all --decorate"
alias gb="git branch"
alias gs="git show"
alias gd="diff --color --color-words --abbrev"
alias gdc="git diff --cached"
alias gbl="git blame"
alias gps="git push"
alias gpl="git pull"
alias gb="git branch"
alias gd="git diff"
alias go="git checkout "
alias gk="gitk --all&"
alias gx="gitx --all"

# show ignored files by git
alias gx="ign = ls-files -o -i --exclude-standard"

# Untrack Files without deleting them
alias grmc="git rm -r --cached"

# xmrig
alias xmrig="sudo xmrig"
# Utiliser exa pour ls
alias ls='exa --group-directories-first --icons'

# Raccourcis pour 'ls'
alias la='ls -a'
alias ll='ls -l'      #long list
alias lla='ls -la'
alias l='ls -lFh'     #size,show type,human readable
alias lr='ls -tRFh'   #sorted by date,recursive,show type,human readable
alias lt='ls -ltFh'   #long list,sorted by date,show type,human readable
alias ldot='ls -ld .*'
alias lS='ls -1FSsh'
alias lart='ls -1Fcart'
alias lrt='ls -1Fcrt'

# Quelques alias pratiques
alias f="find / -type f | fzf"
alias c='clear'
alias z='source ~/.zshrc'
alias vimz='$EDITOR ~/.zshrc'
alias less='less --quiet'
alias ..='cd ..'
alias df='df --human-readable'
alias du='du --human-readable'
alias nfetch='neofetch --config ~/dotfiles/neofetch'
alias date-computer='date +"%Y-%m-%d_%H:%M:%S"'
alias date-human='date +"%A %d %B %Y, %H:%M"'
alias top="btop"
