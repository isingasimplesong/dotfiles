    if [ -f /etc/os-release ]; then
        source /etc/os-release
        # Check for Arch Linux distribution
        if [[ "$ID" == "arch" ]]; then
            # Arch-specific settings
        # Check for Debian distribution
        elif [[ "$ID" == "debian" ]]; then
            # Debian-specific settings
        fi
    fi
fi


zstyle ':completion:*' menu select
fpath+=~/.zfunc

