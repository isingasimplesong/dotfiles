# --2 bspwm hotkeys

# --2.1 restart bspwm
super + alt + r
	bspc wm -r

# --2.2 close and kill node
super + {_,shift + }q
	bspc node -{c,k}

# --2.3 alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# # --2.4 swap the current node and the biggest window
# super + 
# 	bspc node -s biggest.window

# state/flags

# --2.5 set the window state
super + {t,shift + t,f,shift + f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# --2.6 set the node flags
super + ctrl + {m,x,s,p}
	bspc node -g {marked,locked,sticky,private}


# focus/swap

# --2.7 focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# --2.8 focus the next/previous window in the current desktop
super + {_,shift + }c
	bspc node -f {next,prev}.local.!hidden.window

# --2.9 focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# --2.10 focus the last node/desktop
super + {grave,Tab}
 	bspc {node,desktop} -f last

# # --2.11 focus the older or newer node in the focus history
# super + {o,i}
# 	bspc wm -h off; \
# 	bspc node {older,newer} -f; \
# 	bspc wm -h on

# --2.12 focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'
# send to the given desktop and follow
super + ctrl + {1-9,0}
  bspc node -d '^{1-9,10}' --follow

# preselect

# --2.13 preselect the direction
super + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

# --2.14 preselect the ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# --2.15 cancel the preselection for the focused node
super + ctrl + space
	bspc node -p cancel

# --2.16 cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

# move/resize

# --2.17 expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# --2.18 contract a window by moving one of its side inward
super + alt + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# --2.19 Smart resize 
#will grow or shrink depending on location.
# Will always grow for floating nodes.

super + alt + {Left,Down,Up,Right}
  n=10; \
  { d1=left;   d2=right;  dx=-$n; dy=0;   \
  , d1=bottom; d2=top;    dx=0;   dy=$n;  \
  , d1=top;    d2=bottom; dx=0;   dy=-$n; \
  , d1=right;  d2=left;   dx=$n;  dy=0;   \
  } \
  bspc node --resize $d1 $dx $dy || bspc node --resize $d2 $dx $dy

# --2.20 move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}

# --2.21 switch layouts
super + {comma,period}
  bsp-layout {previous,next} --layouts tall,rtall,wide,rwide,grid

# --2.22 gaps presets
super + g; {y,u,i,o,p}
    bspc config window_gap {0, 8, 16, 32, 64}

# --2.23 dynamic gaps
super + shift + bracket{right,left}
    { bspc config -d focused window_gap $(( $(bspc config -d focused window_gap) + 5 )), \
    [ $(bspc config -d focused window_gap) -ge 5 ] && \
    bspc config -d focused window_gap $(( $(bspc config -d focused window_gap) - 5 )) }

